MONGODB_URI=mongodb://localhost:27017/adiyogi
JWT_SECRET=your_super_secret_jwt_key_here
PORT=5001
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5001

# Admin WhatsApp (country code + number, no +)
ADMIN_WHATSAPP=91XXXXXXXXXX

# Set to 'false' to disable auto-send during development
WHATSAPP_ENABLED=false

# ImageKit CDN
IMAGEKIT_PUBLIC_KEY=your_public_key_here
IMAGEKIT_PRIVATE_KEY=your_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ImageKit Folder Paths
IMAGEKIT_PRODUCT_IMAGES_FOLDER=your_product_image_folder_name
IMAGEKIT_COLLECTION_IMAGES_FOLDER=your_collection_image_folder_name
IMAGEKIT_INVOICES_FOLDER=your_inovices_folder_name
